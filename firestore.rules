rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /app/config {
      allow read: if true;
      allow write: if false;
    }

    match /dashboard/cache {
      allow read: if true;
      allow write: if false;
    }

    match /monitor/status {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
